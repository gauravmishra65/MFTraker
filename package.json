{
  "name": "mf-share-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Indian Share Market & Mutual Fund Tracker — full-stack monorepo",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace server run build && npm --workspace client run build",
    "seed": "npm --workspace server run seed",
    "migrate": "npm --workspace server run migrate"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
